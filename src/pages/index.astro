---
import Layout from "../components/Layout.astro";
import { Image } from "astro:assets";
import wallpaper from "../assets/images/wallpaper.png";
---

<Layout title="星光咖啡厅 | Starlight Cafeteria">
  <div class="relative w-full h-screen overflow-hidden">
    {/* Background Image with slow zoom */}
    <div class="absolute inset-0 hero-bg" style="animation: hero-bg-zoom 20s ease-in-out infinite alternate;">
      <Image
        src={wallpaper}
        alt="星光咖啡厅"
        class="w-full h-full object-cover"
        loading="eager"
      />
    </div>

    {/* Dream Glow Overlay */}
    <div class="absolute inset-0 dream-glow" style="animation: glow-pulse 4s ease-in-out infinite;">
      <div
        class="absolute inset-0"
        style="background: radial-gradient(ellipse at 30% 70%, rgba(227, 116, 199, 0.3) 0%, transparent 50%), radial-gradient(ellipse at 70% 30%, rgba(0, 35, 209, 0.2) 0%, transparent 50%);"
      ></div>
    </div>

    {/* Secondary glow layer */}
    <div
      class="absolute inset-0 dream-glow"
      style="animation: glow-pulse 6s ease-in-out infinite reverse;"
    >
      <div
        class="absolute inset-0"
        style="background: radial-gradient(circle at 50% 50%, rgba(255, 255, 255, 0.08) 0%, transparent 60%);"
      ></div>
    </div>

    {/* Vignette */}
    <div
      class="absolute inset-0"
      style="background: radial-gradient(ellipse at center, transparent 40%, rgba(0, 89, 43, 0.4) 100%);"
    ></div>

    {/* Title */}
    <div class="absolute bottom-12 left-8 md:bottom-16 md:left-16 lg:bottom-20 lg:left-20">
      <h1
        class="text-white font-bold uppercase leading-none"
        style="font-family: 'Oswald', sans-serif; font-size: clamp(2.5rem, 8vw, 6rem); letter-spacing: -2px; text-shadow: 4px 4px 0 #000, 0 0 40px rgba(227, 116, 199, 0.5); animation: hero-float 3s ease-in-out infinite;"
      >
        STARLIGHT
      </h1>
      <h1
        class="text-white font-bold uppercase leading-none mt-1"
        style="font-family: 'Oswald', sans-serif; font-size: clamp(2.5rem, 8vw, 6rem); letter-spacing: -2px; text-shadow: 4px 4px 0 #000, 0 0 40px rgba(227, 116, 199, 0.5); animation: hero-float 3s ease-in-out infinite 0.5s;"
      >
        CAFETERIA
      </h1>
      <p
        class="mt-4 text-white/80 font-bold uppercase tracking-widest"
        style="font-family: 'ZCOOL XiaoWei', cursive; font-size: clamp(1rem, 2.5vw, 1.5rem); text-shadow: 2px 2px 0 #000;"
      >
        魔女的咖啡厅
      </p>
    </div>

    {/* Decorative floating particles */}
    <div class="absolute top-1/4 left-1/4 w-2 h-2 rounded-full bg-brand-quaternary/60 dream-glow" style="animation: glow-pulse 3s ease-in-out infinite 1s;"></div>
    <div class="absolute top-1/3 right-1/3 w-3 h-3 rounded-full bg-brand-tertiary/40 dream-glow" style="animation: glow-pulse 5s ease-in-out infinite 2s;"></div>
    <div class="absolute bottom-1/3 right-1/4 w-2 h-2 rounded-full bg-white/40 dream-glow" style="animation: glow-pulse 4s ease-in-out infinite 0.5s;"></div>
  </div>
</Layout>
