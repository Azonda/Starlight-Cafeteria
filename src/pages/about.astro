---
import Layout from "../components/Layout.astro";
import { Image } from "astro:assets";
import profileAzonda from "../assets/images/Profile_Azonda.jpeg";
import profileStliuen from "../assets/images/Profile_STliuEN.jpeg";

const owners = [
  {
    name: "Azonda",
    title: "店长",
    description: "制作咖啡，烘焙点子，能使出非常不稳定的魔法",
    github: "https://github.com/Azonda",
    avatar: profileAzonda,
  },
  {
    name: "STliuEN",
    title: "副店长",
    description: "能把不稳定的魔法变得可靠",
    github: "https://github.com/STliuEN",
    avatar: profileStliuen,
  },
];
---

<Layout title="关于店长 | 星光咖啡厅">
  <div class="min-h-screen bg-brand">
    {/* Header */}
    <div class="px-8 py-12 md:px-16 md:py-16 lg:px-20 lg:py-20">
      <h1
        class="text-white font-bold uppercase leading-none"
        style="font-family: 'Oswald', sans-serif; font-size: clamp(2.5rem, 6vw, 4rem); letter-spacing: -1px; text-shadow: 4px 4px 0 #000;"
      >
        ABOUT US
      </h1>
      <p
        class="mt-3 text-white/70 font-bold uppercase tracking-widest"
        style="font-family: 'ZCOOL XiaoWei', cursive; font-size: clamp(1rem, 2vw, 1.25rem);"
      >
        关于店长
      </p>
    </div>

    {/* Owner Cards */}
    <div class="px-8 pb-20 md:px-16 lg:px-20">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-4xl mx-auto">
        {owners.map((owner) => (
          <div class="bg-white rounded-[20px] border-4 border-black shadow-[8px_8px_0_0_#000] overflow-hidden">
            {/* Avatar */}
            <div class="p-6 pb-0 flex justify-center">
              <div class="relative">
                <div class="w-32 h-32 rounded-full border-4 border-black overflow-hidden shadow-[4px_4px_0_0_#000]">
                  <Image
                    src={owner.avatar}
                    alt={owner.name}
                    class="w-full h-full object-cover"
                    width={128}
                    height={128}
                  />
                </div>
              </div>
            </div>

            {/* Info */}
            <div class="p-6 text-center">
              <h2
                class="text-brand font-bold uppercase text-2xl"
                style="font-family: 'Oswald', sans-serif"
              >
                {owner.name}
              </h2>
              <p class="text-brand-tertiary font-bold uppercase text-sm mt-1 tracking-wider">
                {owner.title}
              </p>
              <p class="text-brand/80 mt-4 text-base leading-relaxed">
                {owner.description}
              </p>

              {/* GitHub Link */}
              <div class="mt-6">
                <a
                  href={owner.github}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center gap-3 px-6 py-3 bg-white rounded-[20px] border-4 border-black shadow-[6px_6px_0_0_#000] hover:shadow-[10px_10px_0_0_#000] hover:-translate-x-0.5 hover:-translate-y-0.5 transition-all duration-500 text-brand font-bold uppercase text-base skew-x-[-15deg]"
                  style="font-family: 'Oswald', sans-serif"}
                >
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" className="skew-x-[15deg]">
                    <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
                  </svg>
                  <span class="skew-x-[15deg]">GitHub</span>
                </a>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</Layout>
